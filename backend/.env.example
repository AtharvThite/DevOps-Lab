PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/devops_automation
FRONTEND_ORIGIN=http://localhost:5173

# General
PIPELINE_WORK_DIR=workdir
GIT_BINARY=git

# SonarQube
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=replace_with_sonar_token
SONAR_SCANNER_BINARY=sonar-scanner

# Terraform
TERRAFORM_PATH=terraform
TERRAFORM_BINARY=terraform

# Ansible
ANSIBLE_PATH=ansible
ANSIBLE_BINARY=ansible-playbook
ANSIBLE_INVENTORY_FILE=inventory.ini
ANSIBLE_PLAYBOOK_FILE=deploy.yml

# Deployment
DEPLOYMENT_TARGET=multipass
MULTIPASS_BINARY=multipass
LXD_BINARY=lxc
LXD_IMAGE=ubuntu:22.04

# Optional post-launch command executed inside instance/container
# Example: DEPLOYMENT_EXEC_COMMAND="sudo systemctl restart my-service"
DEPLOYMENT_EXEC_COMMAND=
