PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/devops_automation
FRONTEND_ORIGIN=http://localhost:5173

# Set to false to run real CLI commands
SIMULATE_PIPELINE=true
SIMULATE_SONAR_FAIL=false
SONAR_FAIL_PATTERN=QUALITY GATE STATUS: FAILED
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=

SONAR_COMMAND=bash ./infra/scripts/run_sonar.sh
TERRAFORM_INIT_COMMAND=bash ./infra/scripts/run_terraform.sh init
TERRAFORM_APPLY_COMMAND=bash ./infra/scripts/run_terraform.sh apply
ANSIBLE_COMMAND=bash ./infra/scripts/run_ansible.sh

# multipass or lxd
DEPLOYMENT_TARGET=lxd
MULTIPASS_COMMAND=multipass launch
LXD_COMMAND=bash ./infra/scripts/deploy_lxd.sh

# Runtime variables used by infra scripts
LXD_CONTAINER_NAME=devops-lab-app
LXD_PROFILE_NAME=devops-lab-profile
LXD_IMAGE=ubuntu:22.04
LXD_STORAGE_POOL=default
LXD_NETWORK=lxdbr0
LXD_CPU=2
LXD_MEMORY=2GB
APP_DIR=/opt/devops-lab
