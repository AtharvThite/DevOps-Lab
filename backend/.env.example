PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/devops_automation
FRONTEND_ORIGIN=http://localhost:5173

# Set to false to run real CLI commands
SIMULATE_PIPELINE=true
SIMULATE_SONAR_FAIL=false
SONAR_FAIL_PATTERN=QUALITY GATE STATUS: FAILED

SONAR_COMMAND=sonar-scanner
TERRAFORM_INIT_COMMAND=terraform init
TERRAFORM_APPLY_COMMAND=terraform apply -auto-approve
ANSIBLE_COMMAND=ansible-playbook playbook.yml

# multipass or lxd
DEPLOYMENT_TARGET=multipass
MULTIPASS_COMMAND=multipass launch
LXD_COMMAND=lxc launch ubuntu:22.04 app-instance
